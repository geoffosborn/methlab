# MethLab Environment Configuration
# Copy to .env and fill in values

# Carbon Mapper public API (default works without a key)
CARBON_MAPPER_API_BASE=https://api.carbonmapper.org/api/v1

# MethLab API backend (optional, for DEKS integration)
# METHLAB_API_BASE=http://localhost:8020

# Port (default 3100, must match systemd service)
PORT=3100
